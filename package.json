{
  "name": "dizimo_digital",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n API,WEB \"npm run dev:api\" \"npm run dev:web:wait\"",
    "dev:api": "vercel dev --listen 3000 --yes",
    "dev:web:wait": "wait-on tcp:3000 && npm run dev:web",
    "dev:web": "vite",
    "db:up": "docker-compose up -d db",
    "db:down": "docker-compose down",
    "db:ready": "wait-on tcp:5433",
    "db:init": "npm run db:up && npm run db:ready && npm run db:generate && npm run db:migrate -- --name init && npm run db:seed",
    "db:restart": "docker-compose restart db",
    "app:restart": "npm run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^5.20.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prisma": "^5.20.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vercel": "^48.4.0",
    "vite": "^8.0.10",
    "wait-on": "^9.0.1"
  }
}
